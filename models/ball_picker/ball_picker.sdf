<?xml version="1.0"?>
<sdf version="1.10">
  <model name="ball_picker">
    <pose>0 0 0.08 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>11.5</mass>
        <inertia>
          <ixx>0.24</ixx>
          <iyy>0.36</iyy>
          <izz>0.44</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="body_collision">
        <pose>0 0 0.22 0 0 0</pose>
        <geometry>
          <box>
            <size>0.62 0.46 0.30</size>
          </box>
        </geometry>
      </collision>
      <visual name="body_visual">
        <pose>0 0 0.22 0 0 0</pose>
        <geometry>
          <box>
            <size>0.62 0.46 0.30</size>
          </box>
        </geometry>
        <material>
          <ambient>0.10 0.12 0.15 1</ambient>
          <diffuse>0.14 0.18 0.22 1</diffuse>
          <specular>0.25 0.25 0.25 1</specular>
        </material>
      </visual>
      <visual name="hopper_visual">
        <pose>-0.08 0 0.43 0 0 0</pose>
        <geometry>
          <box>
            <size>0.38 0.38 0.18</size>
          </box>
        </geometry>
        <material>
          <ambient>0.07 0.30 0.34 1</ambient>
          <diffuse>0.09 0.42 0.48 1</diffuse>
        </material>
      </visual>
      <visual name="pickup_mouth">
        <pose>0.38 0 0.08 0 0 0</pose>
        <geometry>
          <box>
            <size>0.18 0.52 0.11</size>
          </box>
        </geometry>
        <material>
          <ambient>0.78 0.86 0.12 1</ambient>
          <diffuse>0.86 0.95 0.15 1</diffuse>
        </material>
      </visual>
      <visual name="front_camera">
        <pose>0.34 0 0.43 0 0 0</pose>
        <geometry>
          <box>
            <size>0.06 0.16 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
      <visual name="lidar_disc">
        <pose>0.05 0 0.55 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.09</radius>
            <length>0.045</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.03 0.03 0.035 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel">
      <pose>0 0.285 0.10 1.5708 0 0</pose>
      <inertial>
        <mass>0.7</mass>
        <inertia>
          <ixx>0.0012</ixx>
          <iyy>0.0012</iyy>
          <izz>0.0012</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.03 0.03 0.03 1</diffuse></material>
      </visual>
    </link>

    <link name="right_wheel">
      <pose>0 -0.285 0.10 1.5708 0 0</pose>
      <inertial>
        <mass>0.7</mass>
        <inertia>
          <ixx>0.0012</ixx>
          <iyy>0.0012</iyy>
          <izz>0.0012</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.055</length>
          </cylinder>
        </geometry>
        <material><ambient>0.02 0.02 0.02 1</ambient><diffuse>0.03 0.03 0.03 1</diffuse></material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.57</wheel_separation>
      <wheel_radius>0.10</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>/ball_picker/cmd_vel</topic>
      <odom_topic>/ball_picker/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </model>
</sdf>
